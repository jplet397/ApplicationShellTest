{
  "name": "application-shell-test",
  "version": "0.1.0",
  "scripts": {
    "start:all": "npm-run-all --parallel start:shell start:mfe1 start:about",
    "start": "webpack serve --config webpack.config.js",
    "start:shell": "webpack serve --config webpack.config.js",
    "start:mfe1": "webpack serve --config webpack.mfe1.config.js",
    "start:about": "webpack serve --config webpack.about.config.js",
    "build": "npm run lint:shell && cross-env NODE_ENV=production webpack --config webpack.config.js",
    "build:shell": "npm run lint:shell && cross-env NODE_ENV=production webpack --config webpack.config.js",
    "build:mfe1": "npm run lint:mfe1 && cross-env NODE_ENV=production webpack --config webpack.mfe1.config.js",
    "build:about": "npm run lint:shell && cross-env NODE_ENV=production webpack --config webpack.about.config.js",
    "lint:shell": "eslint \"src/shell/**/*.ts\" \"src/features/**/*.ts\" \"src/about-module/**/*.ts\"",
    "lint:mfe1": "biome check src/mfe1/",
    "lint": "npm run lint:shell && npm run lint:mfe1",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^25.8.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "eslint": "^10.3.0",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.7",
    "mini-css-extract-plugin": "^2.10.2",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.14",
    "postcss-loader": "^8.2.1",
    "postcss-preset-env": "^11.3.0",
    "raw-loader": "^4.0.2",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.8",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.3",
    "webpack": "^5.106.2",
    "webpack-bundle-analyzer": "^5.3.0",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.4"
  },
  "dependencies": {
    "rxj": "^0.0.0-alpha.0",
    "rxjs": "^7.8.2"
  }
}
